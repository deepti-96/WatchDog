# Dashboard and storage
WATCHDOG_STATE_DIR=/data/watchdog
PORT=3000

# Demo database
# json-files = original filesystem incident JSON files
# sqlite = real SQLite incident database stored under WATCHDOG_STATE_DIR or WATCHDOG_DATABASE_URL
WATCHDOG_STORAGE=sqlite
WATCHDOG_DATABASE_URL=/data/watchdog/watchdog.sqlite

# Explanation mode
# auto = try Ollama, then fallback to the built-in lightweight explainer
# local = always use built-in lightweight explainer
# ollama = require Ollama and return an error if it is unavailable
WATCHDOG_EXPLAINER=local
WATCHDOG_OLLAMA_BASE_URL=http://localhost:11434/api
WATCHDOG_OLLAMA_MODEL=gemma3

# Demo seed used by the Docker image on start
WATCHDOG_DEMO_DEPLOY=v3.2.1
WATCHDOG_DEMO_ENVIRONMENT=demo
